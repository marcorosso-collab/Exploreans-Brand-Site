---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Letter from '../components/Letter.astro';
import Pillars from '../components/Pillars.astro';
import Places from '../components/Places.astro';
import Beyond from '../components/Beyond.astro';
import FieldNotes from '../components/FieldNotes.astro';
import Group from '../components/Group.astro';
import Journal from '../components/Journal.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

// Load hero section for OG image
const heroEntry = await getEntry('homepage', 'hero');
const heroData = heroEntry?.data ?? {};
---
<Layout ogImage={heroData.background_image}>
  <Nav />
  <Hero />
  <Letter />
  <Pillars />
  <Places />
  <Beyond />
  <FieldNotes />
  <Group />
  <Journal />
  <Footer />
</Layout>
