---
import { getEntry } from 'astro:content';
const heroEntry = await getEntry('hero', 'hero');
const h = heroEntry!.data;
---
<header class="hero">
  <div
    class="hero-bg"
    style={`background-image: url('${h.background_image}');`}
    role="img"
    aria-label={h.background_alt ?? ''}
  ></div>
  <div class="hero-volume">
    <span class="line"></span>
    <span>{h.volume_label}</span>
  </div>
  <div class="container hero-content">
    <h1 class="hero-title">
      <span class="line-1">{h.title_line_1}</span>
      <span class="line-2">{h.title_line_2}</span>
    </h1>
    <div class="hero-copy">
      <p>{h.body_1}</p>
      <p>{h.body_2}</p>
    </div>
  </div>
  <div class="hero-bottom">
    <span>{h.bottom_left}</span>
    <a href="#letter" class="hero-scroll">
      <span>{h.scroll_label}</span>
      <span class="arrow"></span>
    </a>
  </div>
</header>
