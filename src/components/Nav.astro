---
import { getEntry, getCollection } from 'astro:content';

const navSettings = await getEntry('settings', 'nav');
const nav = navSettings?.data ?? { 
  links: [], 
  cta_label: 'Plan a stay', 
  cta_href: '#places',
  logo: null,
  logo_alt: 'Exploreans',
  wordmark_main: 'Exploreans',
  wordmark_sub: 'Camps · Lodges · Retreats'
};

// Auto-populate Properties dropdown from the properties collection
const properties = (await getCollection('properties'))
  .filter(p => p.data.show_in_nav !== false)
  .sort((a, b) => a.data.order - b.data.order);

const propertiesDropdown = (nav.properties_dropdown && nav.properties_dropdown.length > 0)
  ? nav.properties_dropdown
  : properties.map(p => ({
      label: p.data.short_name,
      href: p.data.cta_href,
      location: p.data.location
    }));
---
<nav class="nav" id="nav" data-nav>
  <div class="container nav-inner">
    <a href="/" class="wordmark" data-logo>
      {nav.logo ? (
        <>
          <img 
            src={nav.logo} 
            alt={nav.logo_alt || 'Exploreans'} 
            class="nav-logo nav-logo--default" 
          />
          <img 
            src={nav.logo} 
            alt={nav.logo_alt || 'Exploreans'} 
            class="nav-logo nav-logo--white" 
          />
        </>
      ) : (
        <>
          <span class="wordmark-main">{nav.wordmark_main}</span>
          <span class="wordmark-sub">{nav.wordmark_sub}</span>
        </>
      )}
    </a>

    <ul class="nav-links" id="navLinks">
      {nav.links?.map((link) => {
        const isProperties = link.label.toLowerCase() === 'properties';
        if (isProperties && propertiesDropdown.length > 0) {
          return (
            <li class="has-dropdown">
              <a href={link.href}>{link.label}</a>
              <ul class="dropdown">
                {propertiesDropdown.map((p) => (
                  <li>
                    <a href={p.href}>
                      {p.label}
                      {p.location && <span class="dd-location">{p.location}</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          );
        }
        return (
          <li><a href={link.href}>{link.label}</a></li>
        );
      })}
    </ul>

    <div class="nav-actions">
      {nav.cta_show_dropdown && propertiesDropdown.length > 0 ? (
        <div class="nav-cta-wrapper has-dropdown">
          <a href={nav.cta_href} class="nav-cta">
            <span>{nav.cta_label}</span>
            <span class="cta-arrow">▼</span>
          </a>
          <ul class="dropdown cta-dropdown">
            {propertiesDropdown.map((p) => (
              <li>
                <a href={p.href}>
                  {p.label}
                  {p.location && <span class="dd-location">{p.location}</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ) : (
        <a href={nav.cta_href} class="nav-cta"><span>{nav.cta_label}</span></a>
      )}
      
      <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<style>
  .nav-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }
  
  .nav-logo--default {
    opacity: 1;
  }
  
  .nav-logo--white {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    filter: brightness(0) invert(1);
  }
  
  /* When nav is at top (no scroll), show white logo */
  [data-nav].at-top .nav-logo--default {
    opacity: 0;
  }
  
  [data-nav].at-top .nav-logo--white {
    opacity: 1;
  }
  
  [data-logo] {
    position: relative;
    display: inline-block;
  }
  
  /* Nav Actions (CTA + Hamburger) */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  
  .nav-cta-wrapper {
    position: relative;
    display: inline-block;
  }
  
  .cta-arrow {
    margin-left: 6px;
    font-size: 10px;
  }
  
  .cta-dropdown {
    right: 0;
    left: auto;
    min-width: 200px;
  }
  
  .nav-cta-wrapper:hover .cta-dropdown,
  .nav-cta-wrapper:focus-within .cta-dropdown {
    display: block;
    opacity: 1;
    visibility: visible;
  }
  
  /* Mobile Menu Toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 101;
  }
  
  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white);
    transition: all 0.3s ease;
  }
  
  /* Hamburger is white at top, dark when scrolled */
  [data-nav]:not(.at-top) .nav-toggle span {
    background: var(--moss);
  }
  
  .nav-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .nav-toggle.active span:nth-child(2) { opacity: 0; }
  .nav-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }
  
  /* Prevent text wrapping before hamburger appears */
  .nav-links {
    white-space: nowrap;
  }
  
  /* Tablet/Mobile - Switch to hamburger menu at 1100px (slightly earlier to prevent wrapping) */
  @media (max-width: 1100px) {
    .nav-toggle { display: flex; }
    
    .nav-links {
      position: fixed;
      top: 0;
      right: 0;
      width: 70%;
      min-width: 280px;
      max-width: 320px;
      height: 100vh;
      min-height: 100vh;
      background: var(--moss);
      flex-direction: column;
      padding: 80px 40px 40px;
      gap: 0;
      transition: transform 0.3s ease, opacity 0.3s ease;
      z-index: 100;
      transform: translateX(100%);
      opacity: 0;
      pointer-events: none;
      align-items: flex-start;
      display: flex;
    }
    
    .nav-links.active { 
      transform: translateX(0);
      opacity: 1;
      pointer-events: auto;
      display: flex;
    }
    
    .nav-links li { 
      width: 100%;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    
    .nav-links a { 
      color: var(--white) !important; 
      font-size: 14px;
      display: block;
      padding: 16px 0;
      white-space: normal;
    }
    
    .nav-links a::after { display: none; }
    
    /* Mobile dropdown styling */
    .nav-links .dropdown {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      background: transparent;
      border: none;
      box-shadow: none;
      padding: 0 0 16px 16px;
      min-width: auto;
    }
    
    .nav-links .dropdown a {
      font-size: 13px;
      padding: 10px 0;
      color: rgba(255,255,255,0.8) !important;
    }
    
    .nav-links .has-dropdown > a::before { display: none; }
    
    /* Keep CTA button styling consistent */
    .nav-cta {
      padding: 10px 20px;
      font-size: 10px;
    }
  }
  
  /* Ensure mobile menu stays visible on very small screens */
  @media (max-width: 480px) {
    .nav-links {
      width: 85%;
      min-width: 260px;
      padding: 70px 30px 30px;
    }
    
    .nav-links.active {
      transform: translateX(0);
      opacity: 1;
      display: flex;
    }
  }
</style>

<script>
  // Handle scroll-based logo color inversion
  const nav = document.querySelector('[data-nav]');
  
  function updateNavState() {
    if (!nav) return;
    
    const scrollY = window.scrollY || window.pageYOffset;
    
    // As soon as user starts scrolling (scrollY > 0), remove at-top class
    if (scrollY > 0) {
      nav.classList.remove('at-top');
    } else {
      nav.classList.add('at-top');
    }
  }
  
  // Initial state
  updateNavState();
  
  // Update on scroll
  window.addEventListener('scroll', updateNavState, { passive: true });
  window.addEventListener('resize', updateNavState, { passive: true });
  
  // Mobile menu toggle
  const navToggle = document.getElementById('navToggle');
  const navLinks = document.getElementById('navLinks');
  
  if (navToggle && navLinks) {
    navToggle.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      this.classList.toggle('active');
      navLinks.classList.toggle('active');
    });
    
    // Close menu when clicking a link
    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        navToggle.classList.remove('active');
        navLinks.classList.remove('active');
      });
    });
    
    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (!nav.contains(e.target) && navLinks.classList.contains('active')) {
        navToggle.classList.remove('active');
        navLinks.classList.remove('active');
      }
    });
  }
</script>
