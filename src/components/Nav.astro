---
import { getEntry, getCollection } from 'astro:content';

const navSettings = await getEntry('settings', 'nav');
const nav = navSettings?.data ?? { 
  links: [], 
  cta_label: 'Plan a stay', 
  cta_href: '#places',
  logo: null,
  logo_alt: 'Exploreans',
  wordmark_main: 'Exploreans',
  wordmark_sub: 'Camps · Lodges · Retreats'
};

// Auto-populate Properties dropdown from the properties collection
const properties = (await getCollection('properties'))
  .filter(p => p.data.show_in_nav !== false)
  .sort((a, b) => a.data.order - b.data.order);

const propertiesDropdown = (nav.properties_dropdown && nav.properties_dropdown.length > 0)
  ? nav.properties_dropdown
  : properties.map(p => ({
      label: p.data.short_name,
      href: p.data.cta_href,
      location: p.data.location
    }));
---
<nav class="nav" id="nav" data-nav>
  <div class="container nav-inner">
    <a href="/" class="wordmark" data-logo>
      {nav.logo ? (
        <img 
          src={nav.logo} 
          alt={nav.logo_alt || 'Exploreans'} 
          class="nav-logo nav-logo--default" 
        />
        <img 
          src={nav.logo} 
          alt={nav.logo_alt || 'Exploreans'} 
          class="nav-logo nav-logo--white" 
        />
      ) : (
        <>
          <span class="wordmark-main">{nav.wordmark_main}</span>
          <span class="wordmark-sub">{nav.wordmark_sub}</span>
        </>
      )}
    </a>

    <ul class="nav-links">
      {nav.links?.map((link) => {
        const isProperties = link.label.toLowerCase() === 'properties';
        if (isProperties && propertiesDropdown.length > 0) {
          return (
            <li class="has-dropdown">
              <a href={link.href}>{link.label}</a>
              <ul class="dropdown">
                {propertiesDropdown.map((p) => (
                  <li>
                    <a href={p.href}>
                      {p.label}
                      {p.location && <span class="dd-location">{p.location}</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          );
        }
        return (
          <li><a href={link.href}>{link.label}</a></li>
        );
      })}
    </ul>

    {nav.cta_show_dropdown && propertiesDropdown.length > 0 ? (
      <div class="nav-cta-wrapper has-dropdown">
        <a href={nav.cta_href} class="nav-cta">
          <span>{nav.cta_label}</span>
          <span class="cta-arrow">▼</span>
        </a>
        <ul class="dropdown cta-dropdown">
          {propertiesDropdown.map((p) => (
            <li>
              <a href={p.href}>
                {p.label}
                {p.location && <span class="dd-location">{p.location}</span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ) : (
      <a href={nav.cta_href} class="nav-cta"><span>{nav.cta_label}</span></a>
    )}
  </div>
</nav>

<style>
  .nav-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }
  
  .nav-logo--default {
    opacity: 1;
  }
  
  .nav-logo--white {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    filter: brightness(0) invert(1);
  }
  
  /* When nav is at top (no scroll), show white logo */
  [data-nav].at-top .nav-logo--default {
    opacity: 0;
  }
  
  [data-nav].at-top .nav-logo--white {
    opacity: 1;
  }
  
  [data-logo] {
    position: relative;
    display: inline-block;
  }
  
  .nav-cta-wrapper {
    position: relative;
    display: inline-block;
  }
  
  .cta-arrow {
    margin-left: 6px;
    font-size: 10px;
  }
  
  .cta-dropdown {
    right: 0;
    left: auto;
    min-width: 200px;
  }
  
  .nav-cta-wrapper:hover .cta-dropdown,
  .nav-cta-wrapper:focus-within .cta-dropdown {
    display: block;
    opacity: 1;
    visibility: visible;
  }
</style>

<script>
  // Handle scroll-based logo color inversion
  const nav = document.querySelector('[data-nav]');
  const hero = document.querySelector('.hero');
  
  function updateNavState() {
    if (!nav || !hero) return;
    
    const heroBottom = hero.getBoundingClientRect().bottom;
    const navHeight = nav.offsetHeight;
    
    // If we've scrolled past the hero section, remove at-top class
    if (heroBottom <= navHeight) {
      nav.classList.remove('at-top');
    } else {
      nav.classList.add('at-top');
    }
  }
  
  // Initial state
  updateNavState();
  
  // Update on scroll
  window.addEventListener('scroll', updateNavState, { passive: true });
  window.addEventListener('resize', updateNavState, { passive: true });
</script>
