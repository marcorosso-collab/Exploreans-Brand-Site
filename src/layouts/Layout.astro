---
import '../styles/global.css';
import { getEntry } from 'astro:content';

const general = await getEntry('settings', 'general');
const g = general?.data ?? {};

export interface Props {
  title?: string;
  description?: string;
}

const { title = g.site_title, description = g.meta_description } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {g.meta_keywords && <meta name="keywords" content={g.meta_keywords} />}
  <meta property="og:title" content={g.og_title ?? title} />
  <meta property="og:description" content={g.og_description ?? description} />
  <meta property="og:type" content="website" />
  {g.og_image && <meta property="og:image" content={g.og_image} />}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Archivo:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Exploreans",
    "alternateName": "Exploreans — Camps, Lodges & Retreats",
    "description": description,
    "url": "https://exploreans.com",
    "parentOrganization": {
      "@type": "Organization",
      "name": "Planhotel Hospitality Group",
      "url": "https://planhotel.com",
      "address": { "@type": "PostalAddress", "addressLocality": "Lugano", "addressCountry": "CH" }
    },
    "slogan": "Authentic by Nature"
  })} />
</head>
<body>
  <slot />

  <script>
    // Nav scroll state
    const nav = document.getElementById('nav');
    if (nav) {
      const toggle = () => nav.classList.toggle('scrolled', window.scrollY > 80);
      toggle();
      window.addEventListener('scroll', toggle, { passive: true });
    }

    // Intersection reveals
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>
</body>
</html>
